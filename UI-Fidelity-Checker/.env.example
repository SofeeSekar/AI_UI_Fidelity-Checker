# Copy this file to ".env" (same folder) and fill in your real values.
# The .env file stays on your machine and is git-ignored — never commit it.

# Pick ONE engine:
#  - GEMINI_API_KEY  : free, get it at https://aistudio.google.com/apikey
#  - ANTHROPIC_API_KEY: paid, higher quality (console.anthropic.com)
# If GEMINI_API_KEY is set it is used (free); otherwise ANTHROPIC_API_KEY.

GEMINI_API_KEY=your_google_ai_studio_key
# ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# Optional, only for the "Advanced: Figma link" mode (needs a Figma Dev seat):
# FIGMA_TOKEN=figd_your_figma_personal_access_token
